---
import { render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import ArticleRightRail from "../../components/blog/ArticleRightRail.astro";
import Icon from "../../components/blog/Icon.astro";
import {
  formatDate,
  getAdjacentPosts,
  getAllPosts,
  getHeadingsFromMarkdown,
  getPostAuthors,
  getPostCover,
  getPostDescription,
  getRelatedPosts,
} from "../../lib/blog";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const [readingMinutes] = post.readingTime.split(" ");
const absoluteUrl = new URL(post.permalink, Astro.site ?? Astro.url).href;
const adjacent = getAdjacentPosts(posts, post.slug);
const relatedPosts = getRelatedPosts(posts, post);
const headings = post.data.toc === false ? [] : getHeadingsFromMarkdown(post.body);
const cover = getPostCover(post);
const description = getPostDescription(post);
const recentPosts = posts
  .filter((item) => item.slug !== post.slug)
  .slice(0, 5)
  .map((item) => ({
    href: item.permalink,
    title: item.data.title,
    meta: `${formatDate(item.data.date)} · ${item.readingTime}`,
  }));
const relatedRailPosts = relatedPosts.map((item) => ({
  href: item.permalink,
  title: item.data.title,
  meta: `${formatDate(item.data.date)} · ${item.readingTime}`,
}));
const shareLinks = {
  x: `https://twitter.com/intent/tweet?url=${encodeURIComponent(absoluteUrl)}&text=${encodeURIComponent(post.data.title)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(absoluteUrl)}`,
  telegram: `https://t.me/share/url?url=${encodeURIComponent(absoluteUrl)}&text=${encodeURIComponent(post.data.title)}`,
};
---

<BlogLayout
  title={`${post.data.title} | Field Notes`}
  description={description}
  currentPath={post.permalink}
  image={cover.path}
  type="article"
  pageLabel="Post"
>
  <div class="article-shell">
    <article class="post-layout post-layout--editorial">
      <header class="post-header post-header--editorial">
        <div class="post-header__breadcrumbs">
          <a href="/">Home</a>
          <span>›</span>
          <a href="/blog">Blog</a>
          <span>›</span>
          <span>{post.data.title}</span>
        </div>
        <h1>{post.data.title}</h1>
        <div class="post-meta post-meta--editorial">
          <div class="post-meta__details post-meta__details--compact">
            <span class="post-meta__item post-meta__item--compact">
              <span class="post-meta__value">{formatDate(post.data.date)}</span>
            </span>
            {post.data.updatedDate && (
              <span class="post-meta__item post-meta__item--compact">
                <span class="post-meta__label">Updated</span>
                <span class="post-meta__value">{formatDate(post.data.updatedDate)}</span>
              </span>
            )}
            <span class="post-meta__item post-meta__item--compact">
              <span class="post-meta__value">{readingMinutes} min read</span>
            </span>
          </div>
        </div>
      </header>

      {cover.path && (
        <figure class="post-cover">
          <img src={cover.path} alt={cover.alt ?? post.data.title} />
        </figure>
      )}

      <div class="post-prose">
        <Content />
      </div>

      <footer class="post-footer">
        <div class="post-share">
          <div class="post-share__meta">
            <span class="section-eyebrow">Share & rights</span>
            <p>This post is published under CC BY 4.0 and can be shared with attribution.</p>
          </div>
          <div class="post-share__actions">
            <a href={shareLinks.x} target="_blank" rel="noreferrer">
              <Icon name="x-brand" />
              <span>X</span>
            </a>
            <a href={shareLinks.facebook} target="_blank" rel="noreferrer">
              <Icon name="facebook" />
              <span>Facebook</span>
            </a>
            <a href={shareLinks.telegram} target="_blank" rel="noreferrer">
              <Icon name="telegram" />
              <span>Telegram</span>
            </a>
            <button type="button" data-copy-post-link>
              <Icon name="copy" />
              <span>Copy link</span>
            </button>
          </div>
        </div>

        {(adjacent.previous || adjacent.next) && (
          <section class="post-sequence">
            <span class="section-eyebrow">Continue reading</span>
            <div class:list={["post-sequence__grid", { "is-single": !(adjacent.previous && adjacent.next) }]}>
            {adjacent.next ? (
              <a href={adjacent.next.permalink} class="post-sequence__link post-sequence__link--newer">
                <span class="post-sequence__direction">
                  <Icon name="chevron-left" />
                  <span>Newer post</span>
                </span>
                <strong>{adjacent.next.data.title}</strong>
                <small>{formatDate(adjacent.next.data.date)} · {adjacent.next.readingTime}</small>
              </a>
            ) : null}
            {adjacent.previous ? (
              <a href={adjacent.previous.permalink} class="post-sequence__link post-sequence__link--older">
                <span class="post-sequence__direction">
                  <span>Older post</span>
                  <Icon name="chevron-right" />
                </span>
                <strong>{adjacent.previous.data.title}</strong>
                <small>{formatDate(adjacent.previous.data.date)} · {adjacent.previous.readingTime}</small>
              </a>
            ) : null}
            </div>
          </section>
        )}

        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <span class="section-eyebrow">Further Reading</span>
            <div class="related-grid">
              {relatedPosts.map((item) => (
                <a href={item.permalink} class="related-post">
                  <span>{formatDate(item.data.date)}</span>
                  <strong>{item.data.title}</strong>
                  <span>{item.description}</span>
                </a>
              ))}
            </div>
          </section>
        )}

      </footer>
    </article>

    <aside class="article-rail article-rail--right">
      <ArticleRightRail
        toc={headings}
        recentPosts={recentPosts}
        relatedPosts={relatedRailPosts}
      />
    </aside>
  </div>

  <script is:inline>
    (() => {
      const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
      const headings = Array.from(document.querySelectorAll(".post-prose h2, .post-prose h3"));
      const pairs = headings.map((heading, index) => {
        const slug = tocLinks[index]?.getAttribute("data-toc-link") ?? heading.id;
        if (slug) heading.id = slug;

        const text = heading.childNodes[0]?.textContent?.trim() || heading.textContent?.replace(/#$/, "").trim() || "";
        if (!heading.querySelector(".heading-anchor") && heading.id) {
          const anchor = document.createElement("a");
          anchor.href = `#${heading.id}`;
          anchor.className = "heading-anchor";
          anchor.setAttribute("aria-label", `Link to ${text}`);
          anchor.textContent = "#";
          heading.append(anchor);
        }

        return {
          id: heading.id,
          heading,
          link: tocLinks[index] ?? null,
        };
      }).filter((pair) => pair.id);

      const setActive = (activeId) => {
        for (const pair of pairs) {
          const isActive = pair.id === activeId;
          pair.link?.classList.toggle("is-active", isActive);
          if (pair.link) {
            if (isActive) pair.link.setAttribute("aria-current", "true");
            else pair.link.removeAttribute("aria-current");
          }
        }
      };

      const scrollOffset = () => (window.innerWidth < 860 ? 84 : 18);
      const activeOffset = () => (window.innerWidth < 860 ? 112 : 72);
      let pendingTargetId = null;

      const syncActiveSection = () => {
        if (!pairs.length) return;

        if (pendingTargetId) {
          const targetPair = pairs.find((pair) => pair.id === pendingTargetId);
          if (targetPair) {
            const delta = Math.abs(targetPair.heading.getBoundingClientRect().top - scrollOffset());
            if (delta > 18) {
              setActive(pendingTargetId);
              return;
            }
            pendingTargetId = null;
          }
          else {
            pendingTargetId = null;
          }
        }

        if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 32) {
          setActive(pairs[pairs.length - 1].id);
          return;
        }

        const position = window.scrollY + activeOffset();
        let activeId = pairs[0].id;

        for (const pair of pairs) {
          if (pair.heading.offsetTop <= position) activeId = pair.id;
          else break;
        }

        setActive(activeId);
      };

      tocLinks.forEach((link, index) => {
        const pair = pairs[index];
        if (!pair) return;

        link.setAttribute("href", `#${pair.id}`);
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const top = pair.heading.getBoundingClientRect().top + window.scrollY - scrollOffset();
          pendingTargetId = pair.id;
          window.history.replaceState(null, "", `#${pair.id}`);
          window.scrollTo({ top, behavior: "smooth" });
          setActive(pair.id);
        });
      });

      const syncFromHash = () => {
        const hash = window.location.hash.slice(1);
        if (!hash) {
          syncActiveSection();
          return;
        }

        const pair = pairs.find((entry) => entry.id === hash);
        if (pair) {
          pendingTargetId = pair.id;
          setActive(pair.id);
        }
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          syncActiveSection();
          ticking = false;
        });
      };

      syncFromHash();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("hashchange", syncFromHash);

      const copyButton = document.querySelector("[data-copy-post-link]");
      copyButton?.addEventListener("click", async () => {
        const fallbackCopy = () => {
          const input = document.createElement("textarea");
          input.value = window.location.href;
          input.setAttribute("readonly", "");
          input.style.position = "absolute";
          input.style.left = "-9999px";
          document.body.append(input);
          input.select();
          const ok = document.execCommand("copy");
          input.remove();
          return ok;
        };

        try {
          if (navigator.clipboard?.writeText) await navigator.clipboard.writeText(window.location.href);
          else if (!fallbackCopy()) throw new Error("copy-failed");
          copyButton.textContent = "Copied";
          window.setTimeout(() => {
            copyButton.textContent = "Copy link";
          }, 1400);
        } catch {
          if (fallbackCopy()) {
            copyButton.textContent = "Copied";
            window.setTimeout(() => {
              copyButton.textContent = "Copy link";
            }, 1400);
            return;
          }

          copyButton.textContent = "Failed";
          window.setTimeout(() => {
            copyButton.textContent = "Copy link";
          }, 1400);
        }
      });
    })();
  </script>

  {post.data.mermaid && (
    <script type="module" is:inline>
      const looksLikeMermaid = (value) => {
        const source = value.trim();
        return [
          "flowchart",
          "graph ",
          "sequenceDiagram",
          "classDiagram",
          "stateDiagram",
          "erDiagram",
          "journey",
          "gantt",
          "pie ",
          "mindmap",
          "timeline",
        ].some((keyword) => source.startsWith(keyword));
      };

      const { default: mermaid } = await import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs");

      mermaid.initialize({
        startOnLoad: false,
        theme: document.documentElement.dataset.theme === "light" ? "base" : "dark",
        securityLevel: "loose",
      });

      const blocks = Array.from(document.querySelectorAll(".post-prose pre")).filter((block) =>
        looksLikeMermaid(block.textContent ?? ""),
      );

      for (const block of blocks) {
        const container = document.createElement("div");
        container.className = "mermaid";
        container.textContent = block.textContent ?? "";
        block.replaceWith(container);
      }

      mermaid.run({ querySelector: ".post-prose .mermaid" });
    </script>
  )}
</BlogLayout>
