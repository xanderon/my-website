---
import BlogLayout from "../../layouts/BlogLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { getAllPosts, getPinnedPosts } from "../../lib/blog";
import { blogConfig } from "../../data/blog-config";

const posts = await getAllPosts();
const pinnedPosts = getPinnedPosts(posts);
const featuredPost = pinnedPosts[0] ?? posts[0];
const remainingPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
const aboutPost = posts.find((post) => post.slug === "about-me-and-what-youll-find-here");
const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: blogConfig.title,
  description: blogConfig.description,
  url: "https://alexnutu.vercel.app/blog",
  author: {
    "@type": "Person",
    name: "Alex Nutu",
    url: "https://alexnutu.vercel.app/",
  },
};
---

<BlogLayout
  title="Field Notes | Alex Nutu"
  description="Personal notes on practical builds, 3D printing, software, and small maker experiments."
  currentPath="/blog"
  pageLabel="Blog"
  schema={schema}
>
  <section class="blog-landing">
    <header class="blog-landing__hero">
      <div class="blog-landing__intro">
        <span class="blog-hero__eyebrow">Field Notes</span>
        <h1>My place for thoughts on stuff, builds, and how I do some things so I don&apos;t forget.</h1>
        <p>Mostly software, 3D printing, practical builds, and small notes worth keeping around.</p>
        <div class="blog-landing__actions">
          {aboutPost && <a href={aboutPost.permalink}>About me</a>}
          <a href="https://marcelnutu.art/" target="_blank" rel="noreferrer">My father&apos;s art</a>
          <a href="/blog/search">Search</a>
          <a href="/blog/archive">Archive</a>
        </div>
      </div>
    </header>

    {featuredPost && (
      <section class="content-section">
        <div class="section-head">
          <div>
            <span class="section-eyebrow">Featured</span>
            <h2 class="section-title">Start here</h2>
          </div>
          <p>{featuredPost.readingTime}</p>
        </div>
        <div class="post-grid post-grid--featured">
          <PostCard post={featuredPost} />
        </div>
      </section>
    )}

    {remainingPosts.length > 0 && (
      <section class="content-section">
        <div class="section-head">
          <div>
            <span class="section-eyebrow">Latest</span>
            <h2 class="section-title">Recent posts</h2>
          </div>
          <p>{remainingPosts.length} more to read</p>
        </div>
        <div class="post-grid post-grid--stack">
          {remainingPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )}
  </section>
</BlogLayout>
