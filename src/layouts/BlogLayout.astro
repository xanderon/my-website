---
import "../styles/blog.css";
import "katex/dist/katex.min.css";
import BackToTopButton from "../components/blog/BackToTopButton.astro";
import BlogSidebar from "../components/blog/BlogSidebar.astro";
import Icon from "../components/blog/Icon.astro";
import MobileBlogBar from "../components/blog/MobileBlogBar.astro";
import { blogConfig } from "../data/blog-config";

interface Props {
  title: string;
  description: string;
  currentPath: string;
  image?: string;
  type?: "website" | "article";
  pageLabel?: string;
  noindex?: boolean;
  schema?: Record<string, any> | Record<string, any>[] | null;
}

const {
  title,
  description,
  currentPath,
  image = "/blog-assets/og-blog.svg",
  type = "website",
  pageLabel = "Post",
  noindex = false,
  schema = null,
} = Astro.props;

const canonical = new URL(currentPath, Astro.site ?? Astro.url);
const ogImage = new URL(image, Astro.site ?? Astro.url);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" type="application/rss+xml" title={`${blogConfig.title} RSS Feed`} href="/blog/rss.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>}
    <script is:inline>
      (() => {
        const validChoices = new Set(["system", "dark", "light", "sepia", "moss"]);
        const darkQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const storedTheme = localStorage.getItem("alex-blog-theme");
        const choice = validChoices.has(storedTheme) ? storedTheme : "system";
        const resolvedTheme = choice === "system" ? (darkQuery.matches ? "dark" : "light") : choice;
        const mode = resolvedTheme === "dark" || resolvedTheme === "moss" ? "dark" : "light";
        document.documentElement.dataset.themeChoice = choice;
        document.documentElement.dataset.theme = resolvedTheme;
        document.documentElement.dataset.themeMode = mode;
        document.documentElement.style.colorScheme = mode;
      })();
    </script>
  </head>
  <body class="blog-body">
    <MobileBlogBar pageLabel={pageLabel} />
    <div class="mobile-drawer" data-mobile-drawer>
      <div class="mobile-drawer__overlay" data-drawer-close></div>
      <aside class="mobile-drawer__panel" aria-label="Mobile navigation">
        <button type="button" class="mobile-drawer__close" data-drawer-close aria-label="Close navigation">
          <Icon name="x" />
        </button>
        <BlogSidebar currentPath={currentPath} />
      </aside>
    </div>
    <div class="blog-shell">
      <aside class="blog-shell__sidebar">
        <BlogSidebar currentPath={currentPath} />
      </aside>
      <header class="blog-header">
        <div class="blog-header__inner">
          <a class="blog-brand" href="/blog">
            <span class="blog-brand__eyebrow">Alex Nutu</span>
            <strong>Field Notes</strong>
          </a>
          <nav class="blog-nav" aria-label="Primary">
            <a href="/" class:list={{ active: currentPath === "/" }}>Home</a>
            <a href="/blog" class:list={{ active: currentPath.startsWith("/blog") }}>Blog</a>
          </nav>
        </div>
      </header>
      <main class="blog-main">
        <slot />
      </main>
      <footer class="blog-footer">
        <div class="blog-footer__inner">
          <p>© {currentYear} Alex Nutu. Field Notes for practical builds, software systems, and useful things worth keeping.</p>
          <div class="blog-footer__links">
            <a href="/blog/archive">Archive</a>
            <a href="/blog/rss.xml">RSS</a>
            <a href="mailto:alex.nutu@outlook.com">Contact</a>
          </div>
        </div>
      </footer>
    </div>
    <BackToTopButton />
    <script is:inline>
      (() => {
        const body = document.body;
        const drawer = document.querySelector("[data-mobile-drawer]");
        const openButton = document.querySelector("[data-drawer-open]");
        const closeButtons = Array.from(document.querySelectorAll("[data-drawer-close]"));
        const backToTop = document.querySelector("[data-back-to-top]");

        const setDrawer = (open) => {
          drawer?.classList.toggle("is-open", open);
          body.classList.toggle("drawer-open", open);
        };

        openButton?.addEventListener("click", () => setDrawer(true));
        closeButtons.forEach((button) => button.addEventListener("click", () => setDrawer(false)));
        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape") setDrawer(false);
        });

        const onScroll = () => {
          const shouldShow = window.scrollY > 520 && window.innerWidth < 768;
          backToTop?.classList.toggle("is-visible", shouldShow);
        };

        backToTop?.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
