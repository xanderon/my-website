---
import Icon from "./Icon.astro";

const themes = [
  { value: "system", label: "System" },
  { value: "dark", label: "Dark" },
  { value: "light", label: "Light" },
  { value: "sepia", label: "Sepia" },
  { value: "moss", label: "Moss" },
];
---

<div class="theme-switcher" data-theme-switcher>
  <span class="theme-switcher__icon" aria-hidden="true">
    <Icon name="sun" />
  </span>
  <span class="theme-switcher__label">Theme</span>
  <select class="theme-switcher__select" data-theme-select aria-label="Choose blog theme">
    {themes.map((theme) => <option value={theme.value}>{theme.label}</option>)}
  </select>
</div>

<script is:inline>
  (() => {
    if (window.__alexBlogThemeSwitcherReady) return;
    window.__alexBlogThemeSwitcherReady = true;

    const storageKey = "alex-blog-theme";
    const root = document.documentElement;
    const validChoices = new Set(["system", "dark", "light", "sepia", "moss"]);
    const darkQuery = window.matchMedia("(prefers-color-scheme: dark)");

    const getSelects = () => Array.from(document.querySelectorAll("[data-theme-select]"));

    const resolveTheme = (choice) => {
      if (choice === "system") return darkQuery.matches ? "dark" : "light";
      return choice;
    };

    const modeForTheme = (theme) => (theme === "dark" || theme === "moss" ? "dark" : "light");

    const applyTheme = (choice) => {
      const safeChoice = validChoices.has(choice) ? choice : "system";
      const theme = resolveTheme(safeChoice);
      const mode = modeForTheme(theme);

      root.dataset.themeChoice = safeChoice;
      root.dataset.theme = theme;
      root.dataset.themeMode = mode;
      root.style.colorScheme = mode;

      for (const select of getSelects()) {
        select.value = safeChoice;
      }
    };

    const preferredChoice = () => {
      const stored = localStorage.getItem(storageKey);
      return validChoices.has(stored) ? stored : "system";
    };

    applyTheme(preferredChoice());

    document.addEventListener("change", (event) => {
      const select = event.target?.closest?.("[data-theme-select]");
      if (!select) return;

      localStorage.setItem(storageKey, select.value);
      applyTheme(select.value);
    });

    darkQuery.addEventListener("change", () => {
      if ((root.dataset.themeChoice || "system") === "system") {
        applyTheme("system");
      }
    });
  })();
</script>
