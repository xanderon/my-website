---
import Icon from "./Icon.astro";

interface Props {
  pageLabel?: string;
}

const { pageLabel = "Post" } = Astro.props;
---

<header class="mobile-blogbar">
  <button type="button" class="mobile-blogbar__button" data-drawer-open aria-label="Open navigation">
    <Icon name="menu" />
  </button>
  <strong>{pageLabel}</strong>
  <a href="/blog/search" class="mobile-blogbar__button" aria-label="Search">
    <Icon name="search" />
  </a>
</header>
