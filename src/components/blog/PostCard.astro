---
import type { BlogPost } from "../../lib/blog";
import { formatDate, slugifyTag } from "../../lib/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<article class="post-card">
  <a class:list={["post-card__link", { "post-card__link--text": !post.cover.path }]} href={post.permalink} aria-label={`Read ${post.data.title}`}>
    {post.cover.path ? (
      <img
        class="post-card__image"
        src={post.cover.path}
        alt={post.cover.alt ?? post.data.title}
        loading="lazy"
      />
    ) : null}
    <div class="post-card__content">
      <div class="post-card__meta">
        <span>{formatDate(post.data.date)}</span>
        <span>{post.readingTime}</span>
        {post.data.categories[0] && <span>{post.data.categories.join(" / ")}</span>}
      </div>
      <h2>{post.data.title}</h2>
      <p>{post.description}</p>
      {post.data.tags.length > 0 && (
        <div class="post-card__tags">
          {post.data.tags.slice(0, 3).map((tag) => (
            <a href={`/blog/tag/${slugifyTag(tag)}`} class="tag-pill tag-pill--interactive">
              {tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
